# Paste from https://platform.openai.com/api-keys — no quotes. If you see 401, the key is invalid or revoked; create a new one.
OPENAI_API_KEY=

# Display times in this timezone (default India)
# APP_TIMEZONE=Asia/Kolkata

# MySQL (use same values in phpMyAdmin / your DB client)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=call_analyzer
DB_USER=root
DB_PASSWORD=

# Optional
DB_CHARSET=utf8mb4
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
# APP_BASE_PATH=/call-analyzer
